generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Auth (Auth.js Prisma adapter) ----------

enum Role {
  CUSTOMER
  ADMIN
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  name            String?
  role            Role      @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  orders    Order[]
  cart      Cart?
  addresses Address[]
  reviews   Review[]
  wishlist  WishlistItem[]
}

// R24: product-level favorites, logged-in users only.
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// R19: saved addresses are a checkout prefill convenience — orders keep
// storing the shippingAddress JSON snapshot, never a relation to this table.
model Address {
  id         String   @id @default(cuid())
  userId     String
  title      String
  fullName   String
  phone      String
  address    String
  city       String
  district   String
  postalCode String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Tags & catalog ----------

enum TagType {
  HIERARCHICAL
  FLAT
}

model Tag {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  type      TagType
  parentId  String?
  imageKey  String?
  sortOrder Int     @default(0)

  parent   Tag?         @relation("TagHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Tag[]        @relation("TagHierarchy")
  products ProductTag[]
  sales    SaleTag[]
}

model ProductTag {
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([productId, tagId])
  @@index([tagId])
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  description String
  status      ProductStatus @default(DRAFT)
  isFeatured  Boolean       @default(false)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  images      ProductImage[]
  optionTypes OptionType[]
  variants    Variant[]
  tags        ProductTag[]
  sales       SaleProduct[]
  reviews     Review[]
  wishedBy    WishlistItem[]

  @@index([status, createdAt])
}

// R21: verified-buyer reviews, pre-moderated. One review per product per
// customer; editing resets status to PENDING for re-approval.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id        String       @id @default(cuid())
  productId String
  userId    String
  rating    Int
  text      String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([productId, status])
  @@index([status, createdAt])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  key       String
  alt       String
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)
  variantId String?

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
}

model OptionType {
  id        String @id @default(cuid())
  productId String
  name      String
  sortOrder Int    @default(0)

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  OptionValue[]

  @@index([productId])
}

model OptionValue {
  id           String @id @default(cuid())
  optionTypeId String
  value        String
  sortOrder    Int    @default(0)

  optionType OptionType           @relation(fields: [optionTypeId], references: [id], onDelete: Cascade)
  variants   VariantOptionValue[]

  @@index([optionTypeId])
}

model Variant {
  id         String  @id @default(cuid())
  productId  String
  sku        String? @unique
  priceCents Int
  stock      Int     @default(0)
  isActive   Boolean @default(true)
  // R26: false = made to order — sellable while isActive, stock ignored,
  // never decremented, never reserved.
  trackStock Boolean @default(true)

  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionValues VariantOptionValue[]
  images       ProductImage[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
  reservations StockReservation[]

  @@index([productId])
}

model VariantOptionValue {
  variantId     String
  optionValueId String

  variant     Variant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue OptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@index([optionValueId])
}

// ---------- Sales ----------

enum SaleType {
  PERCENT
  FIXED
}

model Sale {
  id         String   @id @default(cuid())
  name       String
  type       SaleType
  value      Int
  startsAt   DateTime
  endsAt     DateTime
  endedEarly Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  products SaleProduct[]
  tags     SaleTag[]

  @@index([startsAt, endsAt])
}

model SaleProduct {
  saleId    String
  productId String

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([saleId, productId])
  @@index([productId])
}

model SaleTag {
  saleId String
  tagId  String

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([saleId, tagId])
  @@index([tagId])
}

// ---------- Coupons (R23) ----------

// Percent-only codes applied on top of sale pricing; one coupon per order.
// A redemption "counts" while its order is not CANCELLED — cancelling frees
// the slot for both the total cap and the once-per-customer rule.
model Coupon {
  id               String   @id @default(cuid())
  code             String   @unique
  percentOff       Int
  startsAt         DateTime
  endsAt           DateTime
  minSubtotalCents Int      @default(0)
  maxRedemptions   Int?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  redemptions CouponRedemption[]
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  orderId   String   @unique
  email     String
  createdAt DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId, email])
}

// ---------- Commerce ----------

model Cart {
  id           String   @id @default(cuid())
  userId       String?  @unique
  sessionToken String?  @unique
  // R23: normalized coupon code awaiting checkout — validated fresh on every
  // read; deliberately not a foreign key so coupon deletion just invalidates.
  couponCode   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CANCELLED
  FULFILLED
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  email           String
  status          OrderStatus
  subtotalCents   Int
  discountCents   Int         @default(0)
  shippingCents   Int
  totalCents      Int
  shippingAddress Json
  notes           String?
  // R23 snapshots: what was charged must survive coupon edits/deletion.
  couponCode          String?
  couponDiscountCents Int     @default(0)
  paymentProvider String?
  paymentRef      String?
  // R16: KDV rate snapshot at creation — invoices for old orders must show
  // the rate that applied then, not today's setting.
  kdvRatePercent  Int         @default(20)
  placedAt        DateTime    @default(now())
  paidAt          DateTime?
  updatedAt       DateTime    @updatedAt
  // R13: set when marked FULFILLED; all optional.
  carrier        String?
  trackingNumber String?
  shippedAt      DateTime?

  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  items            OrderItem[]
  couponRedemption CouponRedemption?
  reservations     StockReservation[]

  @@index([userId])
  @@index([status, placedAt])
}

model OrderItem {
  id                   String  @id @default(cuid())
  orderId              String
  variantId            String?
  productNameSnapshot  String
  variantLabelSnapshot String
  unitPriceCents       Int
  quantity             Int
  lineTotalCents       Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// R26: a pending order's hold on tracked stock. Availability = stock − active
// (unexpired) reservations; rows are deleted on PAID/cancel and lazily once
// expired. Never money, never a snapshot — safe to cascade away.
model StockReservation {
  id        String   @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, expiresAt])
  @@index([orderId])
}

// ---------- Settings ----------

// Singleton row (id always 1).
model Setting {
  id                         Int      @id @default(1)
  flatShippingCents          Int
  freeShippingThresholdCents Int
  lowStockThreshold          Int      @default(3)
  manualPaymentEnabled       Boolean  @default(false)
  manualPaymentInstructions  String?
  kdvRatePercent             Int      @default(20)
  updatedAt                  DateTime @updatedAt
}
