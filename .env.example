# Copy to .env and adjust. Local values match compose.yaml defaults.
DATABASE_URL="postgresql://mofutenshi:mofutenshi@localhost:15432/mofutenshi"

# Signs guest cart cookies and Auth.js session JWTs.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# Optional: Google OAuth login. The Google button stays hidden until both are
# set. Console: https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
